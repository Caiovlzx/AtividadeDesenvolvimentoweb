<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Document</title>
</head>
<body>
    <h1>Login </h1>
    
    {{#if login}}
        <p>Bem vindo, {{nome}}!</p>
    {{else}}
        <p>Faça login para acessar o conteúdo.</p>
    {{/if}}

    {{#if admin}}
        <p>Você tem privilégios de administrador.</p>
    {{else}}
        <p>Você é um usuário comum.</p>
    {{/if}}

   {{#unless admin}}
        <p>Você não possui privilégios de administrador.</p>
    {{/unless}}

</body>
</html>